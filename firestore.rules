rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Super Admin — only server-side / admin SDK access
    match /superAdmin/{doc} {
      allow read, write: if false;
    }

    // Saloon data — owner can only read/write their own saloon
    match /saloons/{saloonId} {
      allow read: if true; // public read for booking page
      allow write: if request.auth != null && request.auth.uid == saloonId;
    }

    // Tokens — public read, rate-limited write
    match /saloons/{saloonId}/tokens/{tokenId} {
      allow read: if true;
      allow create: if
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 10 &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2;
      allow update, delete: if
        request.auth != null && request.auth.uid == saloonId;
    }

    // Reports — only owner
    match /saloons/{saloonId}/reports/{reportId} {
      allow read, write: if request.auth != null && request.auth.uid == saloonId;
    }
  }
}
